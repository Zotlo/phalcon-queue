{
  "name": "zotlo/phalcon-queue",
  "description": "Dashboard and code-driven configuration for Phalcon 5 queues.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "ext-redis": "*",
    "ext-pcntl": "*",
    "ext-sysvmsg": "*",
    "ext-sockets": "*",
    "ext-phalcon": "5.*",
    "symfony/process": "^5.0",
    "symfony/console": "^5.0",
    "laravel/serializable-closure": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Phalcon\\Queue\\": "./lib"
    },
    "files": [
      "./lib/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Phalcon\\Queue\\Tests\\": "./tests"
    }
  },
  "require-dev": {
    "phalcon/ide-stubs": "^5.8",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "phpunit --testdox",
    "test:unit": "phpunit --testsuite unit --testdox",
    "test:integration": "phpunit --testsuite integration --testdox"
  }
}
